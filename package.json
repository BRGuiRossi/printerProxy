{
  "name": "lar-pizza-printer-proxy",
  "version": "2.0.0",
  "description": "Proxy local para impressora Epson TM-T20X II",
  "main": "printer-proxy.js",
  "bin": "printer-proxy.js",
  "type": "commonjs",
  "scripts": {
    "start": "node printer-proxy.js",
    "build": "pkg . --targets node18-win-x64 --output printer-proxy.exe"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.5",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.18.2",
    "usb": "^1.9.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": "*.js",
    "assets": [
      "node_modules/usb/prebuilds/**/*",
      "node_modules/usb/build/Release/*.node"
    ]
  }
}
